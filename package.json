{
  "name": "express-guard-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Type-safe Express request validation middleware powered by Zod.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @express-guard/core",
    "test": "npm run test --workspace @express-guard/core",
    "test:watch": "npm run test:watch --workspace @express-guard/core",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "example": "npm run dev --workspace express-ts-example",
    "clean": "npm run clean --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
